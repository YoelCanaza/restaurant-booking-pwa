# Copia este archivo como .env y completa con las credenciales de tu proyecto
# (Supabase Dashboard → Settings → API). La anon key es pública por diseño;
# la seguridad real está en las políticas RLS. NUNCA pongas aquí la service_role.
VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
